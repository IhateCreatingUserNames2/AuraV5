# --- Application Settings ---
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET_KEY=change_this_secret_in_production
JWT_ALGORITHM=HS256

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://ceaf_user:ceaf_pass@localhost:5433/ceaf_db

# --- Vector Memory (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY= (Optional for local dev)

# --- Nervous System (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Orchestration (Temporal) ---
TEMPORAL_HOST=localhost:7233

# --- External AI Services ---
OPENROUTER_API_KEY="sk-o8"
E2B_API_KEY="e2b_"

# --- CEAF Specific Configs ---
VRE_DISABLED=true
# THIS IS A SAFE GUARD SYSTEM 
AURA_REFLECTOR_INTERVAL_SECONDS=60
INFERENCE_MODE=vastai
# Options: local, vastai, openrouter
VASTAI_ENDPOINT=http://
CEAF_EMBEDDING_PROVIDER=litellm
MODEL_ID=Qwen/Qwen3.5-9B
CEAF_DEFAULT_EMBEDDING_MODEL=Qwen/Qwen3.5-9B
GEOMETRIC_DIMENSION=4096 
# GEOMETRIC DIMENSION NEEDS TO BE THE SAME AS THE HIDDEN DIMENSIONS IN THE LLM MODEL 
